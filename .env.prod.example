DATABASE_URL=postgresql+asyncpg://sentinela:troque-para-senha-forte@postgres:5432/sentinela

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === API ===
API_SECRET_KEY=gere-uma-chave-com-openssl-rand-hex-32
API_HOST=0.0.0.0
API_PORT=8000
AMBIENTE=producao

# === LLM (LLM-as-Judge) ===
OPENAI_API_KEY=sk-...
MODELO_AVALIACAO=gpt-4o-mini

# === Dashboard ===
SERVIDOR_URL=http://servidor:8000

# === Celery ===
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
